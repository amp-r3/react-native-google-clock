{
  "expo": {
    "name": "Clock",
    "slug": "google-clock",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ampr3.myapp",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "android": {
      "package": "com.ampr3.myapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [],
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",           
          "image": "./assets/images/icon.png",    
          "dark": {
            "image": "./assets/images/icon.png",  
            "backgroundColor": "#000000"          
          },
          "imageWidth": 200                       
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a89fc711-da71-42c2-ad83-c72e58a2c672"
      }
    },
    "icon": "./assets/images/icon.png"
  }
}